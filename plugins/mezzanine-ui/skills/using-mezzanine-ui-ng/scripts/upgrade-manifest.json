  "changelog": [
    {
      "tag": "@mezzanine-ui/ng@1.0.0-rc.4",
      "name": "@mezzanine-ui/ng@1.0.0-rc.4",
      "published": "2026-04-22T08:52:05Z",
      "url": "https://github.com/Mezzanine-UI/mezzanine/releases/tag/%40mezzanine-ui/ng%401.0.0-rc.4",
      "body": "## `@mezzanine-ui/ng@1.0.0-rc.4`\r\n\r\n> Compatibility bump paired with `@mezzanine-ui/core@1.0.4`. No Angular source changed — `MznInputTriggerPopper` already ships with `globalPortal=true` and `MznPopper` already enables `flip()` by default, so the React-side picker fixes in this release cycle do not introduce behaviour changes on the Angular side. Pick this version up together with `core@1.0.4` to stay aligned.\r\n\r\n---\r\n\r\n**Compatibility**: requires `@mezzanine-ui/core` ≥ 1.0.4, `@mezzanine-ui/system` ≥ 1.0.2, `@mezzanine-ui/icons` ≥ 1.0.2\r\n\r\n**Full Changelog**: https://github.com/Mezzanine-UI/mezzanine/compare/@mezzanine-ui/ng@1.0.0-rc.3...@mezzanine-ui/ng@1.0.0-rc.4"
    }
  ],
